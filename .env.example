# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── HTTP / security ─────────────────────────────────────────
# Comma-separated origins for browser CORS (no spaces). Include your Vercel URL and custom domain.
# Example: https://mustwafa.com,https://www.mustwafa.com,https://your-app.vercel.app
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:3000,http://localhost:3000

# Host header allow-list (comma-separated; supports *.suffix wildcards for PaaS).
TRUSTED_HOSTS=localhost,127.0.0.1,mxtwafa.com,www.mxtwafa.com

# Optional: when set, POSTs to approve posts, upload docs, and security demo require header X-Admin-Key
# ADMIN_API_KEY=generate-a-long-random-string

# ── Admin (FastAPI) — required; never use weak passwords in production ─────
# Next.js /admin/login proxies POST /admin/login to this API.
# Local dev: copy to `.env` in the repo root (never commit `.env`). Use a strong unique value in production.
ADMIN_PASSWORD=local-dev-change-me
# Any long random string; must match between deploys that issue `admin_session` cookies.
SECRET_KEY=dev-change-me-to-a-long-random-secret-string

# ── App ────────────────────────────────────────────────────
# PORT is set automatically by Railway — do not set here
